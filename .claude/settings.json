{
  "hooks": {
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash scripts/_pyrun.sh scripts/log_hook.py --tool=claude",
            "shell": "bash"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": ".*",
        "hooks": [
          {
            "type": "command",
            "command": "bash scripts/_pyrun.sh scripts/log_hook.py --tool=claude",
            "shell": "bash"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash scripts/_pyrun.sh scripts/log_hook.py --tool=claude",
            "shell": "bash"
          }
        ]
      }
    ]
  }
}
